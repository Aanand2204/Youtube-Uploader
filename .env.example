# ── Whisper ────────────────────────────────────────────────────────────────────
# tiny | base | small | medium | large
WHISPER_MODEL=base

# ── Ollama / Local LLM ─────────────────────────────────────────────────────────
OLLAMA_MODEL=mistral
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=120

# ── File Storage ───────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
AUDIO_DIR=audio
CREDENTIALS_DIR=credentials

# Full path to ffmpeg.exe (needed if ffmpeg is not on system PATH)
FFMPEG_PATH=path/to/ffmpeg.exe

# ── YouTube OAuth ──────────────────────────────────────────────────────────────
YOUTUBE_TOKEN_FILE=credentials/token.pickle

# ── Upload Limits ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=500
